# Normalize text files
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.xml text eol=lf
*.sh text eol=lf
Makefile* text eol=lf
CMakeLists.txt text eol=lf
*.cpp text eol=lf
*.c text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.cu text eol=lf
*.cuh text eol=lf

# Keep packaged binaries and documents binary-safe
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.so binary
*.a binary
*.dll binary
*.exe binary
*.lib binary
*.bi4 binary
*.vtk binary
*_linux64 binary
